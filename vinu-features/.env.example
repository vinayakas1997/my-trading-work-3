# Data root for run artifacts (manifest.md + features.parquet)
VINU_FEATURES_DATA_DIR=./data

# SQLite registry path
VINU_FEATURES_META_DB_PATH=./data/meta.db

# vinu-stock-price API base URL
VINU_STOCK_API_URL=http://127.0.0.1:8081

# HTTP server bind
VINU_FEATURES_HOST=127.0.0.1
VINU_FEATURES_PORT=8082
