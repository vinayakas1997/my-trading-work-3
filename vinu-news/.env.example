VINU_NEWS_DB_PATH=./data/news.db
VINU_NEWS_STORAGE=sqlite
VINU_NEWS_MODE=ticker
VINU_NEWS_POLL_INTERVAL_SEC=600
VINU_NEWS_HOST=0.0.0.0
VINU_NEWS_PORT=8080

# Cross-service integration
VINU_STOCK_API_URL=http://127.0.0.1:8081
VINU_SHARED_WATCHLIST_PATH=

# Local OpenAI-compatible LLM (Ollama, LM Studio, etc.)
VINU_LLM_BASE_URL=http://127.0.0.1:11434/v1
VINU_LLM_MODEL=llama3.2
VINU_LLM_API_KEY=
VINU_LLM_TTL_SEC=86400

# auto: analyze every newly ingested article in the background automatically.
# manual: only analyze when the "Run LLM Analysis" button / API is used.
VINU_LLM_ANALYSIS_MODE=auto
# Max concurrent background LLM analysis requests.
VINU_LLM_ANALYSIS_CONCURRENCY=3

# Future: FMP ticker news / stock provider
FMP_API_KEY=
